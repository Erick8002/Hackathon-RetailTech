{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "aesgptech-mcp",
      "version": "0.1.0",
      "title": "AESGPTech Caderneta"
    },
    "tools": [
      {
        "name": "sales_summary",
        "title": "Sales summary",
        "description": "Return a snapshot of the store: cash in the drawer today, total receivable on the caderneta, overdue client count, and low-stock product count.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_products",
        "title": "List products",
        "description": "List the demo catalog of products in the AESGPTech caderneta, with price and current stock quantity.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "low_stock_only": {
              "description": "If true, only return products with stock <= 5 units.",
              "type": "boolean"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_clients",
        "title": "List clients",
        "description": "List all caderneta clients with their outstanding debt, number of purchases and overdue days.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "debtors_only": {
              "description": "If true, only return clients with an outstanding debt.",
              "type": "boolean"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_client",
        "title": "Get client details",
        "description": "Return the full caderneta ledger and details for a single client by id.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "client_id": {
              "type": "string",
              "description": "Client id, e.g. 'c1'."
            }
          },
          "required": [
            "client_id"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
